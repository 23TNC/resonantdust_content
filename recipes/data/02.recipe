// content/recipes/data/02.recipe
// Recipe DSL — mirrors 02.json statement-for-statement.
//
// Shows the features 01 doesn't: mid-path nested refs
// (slot.X.Y.owner.slot.A.B), aspect stock writes, blueprint unlock,
// and a when-gated create driven by a variable.

recipe cut_tree {
  input {
    use   slot.0.0 aspect wood    >= 1
    claim slot.1.0 aspect corpus+ >= 1
    share slot.1.0.owner.slot.1.0 is axe
  }
  output {
    duration 10
    style slot.1.0 ltr
    destroy slot.1.0
    slot.0.0 aspect wood -= 1
    create corpus- at slot.1.0.owner.inventory
    create log    at slot.1.0.owner.inventory
    unlock nd_furnace at slot.1.0.owner
  }
}

recipe stick {
  input {
    use   slot.2.0 aspect wood    >= 2
    claim slot.2.1 aspect corpus+ >= 1
    share slot.2.0.owner.slot.1.0 is axe
  }
  output {
    duration 10
    style slot.2.1 ltr
    destroy slot.2.0
    destroy slot.2.1
    create corpus- at slot.2.1.owner.inventory
    let v0 = slot.2.0 aspect wood
    when v0 > 2: create stick at slot.2.1.owner.inventory
    create stick at slot.2.1.owner.inventory
    create stick at slot.2.1.owner.inventory
  }
}

recipe break_rock {
  input {
    use   slot.0.0 aspect stone >= 1
    claim slot.1.0 is corpus
    share slot.1.0.owner.slot.1.0 is pickaxe
  }
  output {
    duration 10
    style slot.1.0 ltr
    destroy slot.1.0
    slot.0.0 aspect stone -= 1
    create corpus- at slot.1.0.owner.inventory
    create stone  at slot.1.0.owner.inventory
  }
}
