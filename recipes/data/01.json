{
  "stack": {
    "up": {
      "triple_corpus": {
        "slots": ["corpus", "corpus", "corpus"],
        "reagents": { "slots": [0] },
        "duration": 10,
        "style": "rtl"
      },
      "dread_remover": {
        "slots": ["dread", "dread"],
        "reagents": { "slots": [0, 1] },
        "duration": 10,
        "style": "ltr"
      },
      "corpus_up": {
        "slots": ["corpus", "corpus"],
        "reagents": { "slots": [0] },
        "output": { "inventory": { "root": ["corpus-"] } },
        "duration": 10,
        "style": "rtl"
      }
    },
    "down": {
      "corpus_down_aspect": {
        "slots": [
          { "aspect": "corpus", "min": 1 },
          "corpus"
        ],
        "reagents": { "slots": [0] },
        "duration": 10,
        "style": "rtl"
      },
      "corpus_down": {
        "slots": ["corpus", "corpus"],
        "reagents": { "slots": [0] },
        "output": { "inventory": { "root": ["corpus"] } },
        "duration": 10,
        "style": "rtl"
      }
    }
  },

  "on_create": {
    "self": {
      "corpus-": {
        "root": "corpus-",
        "reagents": { "roles": ["root"] },
        "output": { "inventory": { "actor": ["corpus"] } },
        "duration": 30,
        "style": "rtl"
      },
      "fleeting": {
        "root": { "aspect": "fleeting", "min": 1 },
        "reagents": { "roles": ["root"] },
        "duration": [
          { "when": { "aspect": "fleeting", "min": 4 }, "seconds": 20 },
          { "when": { "aspect": "fleeting", "min": 3 }, "seconds": 15 },
          { "when": { "aspect": "fleeting", "min": 2 }, "seconds": 10 },
          { "seconds": 5 }
        ],
        "style": "rtl"
      }
    },
    "magnetic": {
      "despair": {
        "hex": "despair",
        "set": {
          "start": {
            "hex": { "drop_locked": true, "surface_locked": true }
          }
        },
        "magnetic": {
          "success": "magnetic.up.despair_success",
          "failure": "magnetic.up.despair_failure"
        },
        "duration": 60,
        "delay": 10,
        "interval": 2,
        "style": "ltr"
      },
      "strike": {
        "hex": "strike",
        "set": {
          "start": {
            "hex": { "drop_locked": true, "surface_locked": true }
          }
        },
        "magnetic": {
          "success": "magnetic.up.strike_success",
          "failure": "magnetic.up.strike_failure"
        },
        "duration": 60,
        "delay": 10,
        "interval": 2,
        "style": "ltr"
      }
    }
  },

  "magnetic": {
    "up": {
      "despair_success": {
        "hex": "despair",
        "root": "dread",
        "reagents": { "roles": ["hex", "root"] },
        "set": {
          "start": {
            "root": { "drop_hold": true }
          }
        },
        "output": { "inventory": { "hex": ["corpus"] } },
        "duration": 10,
        "style": "ltr"
      },
      "despair_failure": {
        "hex": "despair",
        "reagents": { "roles": ["hex"] },
        "output": { "inventory": { "hex": ["dread"] } },
        "duration": 10,
        "style": "ltr"
      },
      "strike_success": {
        "hex": "strike",
        "slots": ["corpus", "corpus", "corpus"],
        "reagents": { "slots": [0, 1, 2], "roles": ["hex"] },
        "set": {
          "start": {
            "root": { "drop_hold": true }
          }
        },
        "output": { "inventory": { "root": ["corpus-", "corpus-", "corpus-"] } },
        "duration": 10,
        "style": "ltr"
      },
      "strike_failure": {
        "hex": "strike",
        "reagents": { "roles": ["hex"] },
        "output": { "inventory": { "hex": ["dread"] } },
        "duration": 10,
        "style": "ltr"
      }
    }
  }
}
