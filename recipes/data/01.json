{
  "stack": {
    "up": {
      "triple_corpus": {
        "slots": ["corpus", "corpus", "corpus"],
        "reagents": { "slots": [0] },
        "duration": 10,
        "style": "rtl"
      },
      "dread_remover": {
        "slots": ["dread", "dread"],
        "reagents": { "slots": [0, 1] },
        "duration": 10,
        "style": "ltr"
      },
      "corpus_up": {
        "slots": ["corpus", "corpus"],
        "reagents": { "slots": [0] },
        "output": { "inventory": { "root": ["corpus-"] } },
        "duration": 10,
        "style": "rtl"
      },
      "despair_failure": {
        "root": "despair",
        "reagents": { "roles": ["root"] },
        "output": { "inventory": { "root": ["dread"] } },
        "duration": 10,
        "style": "ltr"
      },
      "strike_failure": {
        "root": "strike",
        "reagents": { "roles": ["root"] },
        "output": { "inventory": { "root": ["dread"] } },
        "duration": 10,
        "style": "ltr"
      }
    },
    "down": {
      "corpus_down_aspect": {
        "slots": [
          { "aspect": "corpus", "min": 1 },
          "corpus"
        ],
        "reagents": { "slots": [0] },
        "duration": 10,
        "style": "rtl"
      },
      "corpus_down": {
        "slots": ["corpus", "corpus"],
        "reagents": { "slots": [0] },
        "output": { "inventory": { "root": ["corpus"] } },
        "duration": 10,
        "style": "rtl"
      }
    }
  },

  "on_create": {
    "self": {
      "corpus-": {
        "root": "corpus-",
        "reagents": { "roles": ["root"] },
        "output": { "inventory": { "actor": ["corpus"] } },
        "duration": 30,
        "style": "rtl"
      },
      "fleeting": {
        "root": { "aspect": "fleeting", "min": 1 },
        "reagents": { "roles": ["root"] },
        "duration": [
          { "when": { "aspect": "fleeting", "min": 4 }, "seconds": 20 },
          { "when": { "aspect": "fleeting", "min": 3 }, "seconds": 15 },
          { "when": { "aspect": "fleeting", "min": 2 }, "seconds": 10 },
          { "seconds": 5 }
        ],
        "style": "rtl"
      }
    }
  },

  "magnetic": {
    "up": {
      "despair_success": {
        "root": "despair",
        "slots": ["dread"],
        "reagents": { "slots": [0], "roles": ["root"] },
        "output": { "inventory": { "root": ["corpus"] } },
        "duration": 10,
        "style": "ltr"
      },
      "strike_success": {
        "root": "strike",
        "slots": ["corpus", "corpus", "corpus"],
        "reagents": { "slots": [0, 1, 2], "roles": ["root"] },
        "output": { "inventory": { "root": ["corpus-", "corpus-", "corpus-"] } },
        "duration": 10,
        "style": "ltr"
      }
    }
  }
}
