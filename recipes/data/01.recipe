// content/recipes/data/01.recipe
// Recipe DSL — mirrors 01.json statement-for-statement.
//
// hold kinds : use | claim | borrow | share   (default: claim)
// refs       : root | slot.<branch>.<index>   (chain with .owner / .parent)
// whitespace between tokens is insignificant.

recipe triple_corpus {
  input {
    use   slot.1.0 is corpus
    claim slot.1.1 is corpus
    claim slot.1.2 is corpus
  }
  output {
    duration 10
    style slot.1.0 rtl
    destroy slot.1.0
  }
}

recipe dread_remover {
  input {
    use   slot.1.0 is dread
    claim slot.1.1 is dread
  }
  output {
    duration 10
    style slot.1.0 ltr
    destroy slot.1.0
    destroy slot.1.1
  }
}

recipe corpus_b.1 {
  input {
    use   slot.1.0 is corpus
    claim slot.1.1 is corpus
  }
  output {
    duration 10
    style slot.1.0 ltr
    destroy slot.1.0
    create corpus- at slot.1.0.owner.inventory
  }
}

recipe corpus_b.2 {
  input {
    use   slot.2.0 is corpus
    claim slot.2.1 is corpus
  }
  output {
    duration 10
    style slot.2.0 ltr
    destroy slot.2.0
    create corpus at slot.2.0.owner.inventory
  }
}

recipe despair_success {
  input {
    use   root     is despair
    claim slot.1.0 is dread
  }
  output {
    duration 10
    style slot.1.0 ltr
    destroy slot.1.0
    destroy root
    create corpus at slot.1.0.owner.inventory
  }
}

recipe despair_failure {
  input {
    use root is despair
  }
  output {
    duration 10
    style root ltr
    destroy root
    create dread at root.owner.inventory
  }
}

recipe strike_success {
  input {
    use   root     is strike
    claim slot.1.0 is corpus
    claim slot.1.1 is corpus
    claim slot.1.2 is corpus
  }
  output {
    duration 10
    style root ltr
    destroy slot.1.0
    destroy slot.1.1
    destroy slot.1.2
    destroy root
    create corpus- at slot.1.0.owner.inventory
    create corpus- at slot.1.0.owner.inventory
    create corpus- at slot.1.0.owner.inventory
  }
}

recipe strike_failure {
  input {
    use root is strike
  }
  output {
    duration 10
    style root ltr
    destroy root
    create dread at root.owner.inventory
  }
}

recipe corpus- {
  input {
    use root is corpus-
  }
  output {
    duration 30
    style root ltr
    destroy root
    create corpus at root.owner.inventory
  }
}

recipe fleeting {
  input {
    borrow root aspect fleeting >= 1
  }
  output {
    let v0 = root aspect fleeting
    duration 5
    when v0 >= 2: duration 10
    when v0 >= 3: duration 15
    when v0 >= 4: duration 20
    style root rtl
    destroy root
  }
}
