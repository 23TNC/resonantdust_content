{
  "cut_tree": {
    "input": [
      "hex.aspect.wood.min: 1",
      "up.slot.0.aspect.corpus+.min: 1",
      "up.slot.0.owner.up.slot.0.def_id: axe"
    ],
    "output": [
      "sys.duration.set: 10",
      "sys.style.set: rtl",
      "up.slot.0.destroy",
      "hex.aspect.wood.sub: 1",
      "up.slot.0.owner.inventory.create: corpus-",
      "up.slot.0.owner.inventory.create: log"
    ]
  },

  "break_rock": {
    "input": [
      "hex.aspect.stone.min: 1",
      "up.slot.0.def_id: corpus"
    ],
    "output": [
      "sys.duration.set: 10",
      "sys.style.set: rtl",
      "up.slot.0.destroy",
      "hex.aspect.stone.sub: 1",
      "up.slot.0.owner.inventory.create: corpus-",
      "up.slot.0.owner.inventory.create: stone"
    ]
  }
}
