; visual facets for faculties.rd — split out of content/data.
<card>

  ::corpus>
    :visuals>
      @define>
        $shape.generic &shape set
        #E67E7E &color.bg set
        #ecd6aa &color.title set
        #0b1426 &color.text set
        $asset::symbols &pack set
        corpus &variant set
      @init>
        $functions::rect_card call drop
      @update>
        $functions::rect_card call drop
      @destroy>
        $functions::rect_card call drop
        $functions::card_death call drop

